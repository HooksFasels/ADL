generator client {
  provider        = "prisma-client"
  output          = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  SUPER_ADMIN
  COLLEGE_ADMIN
  TRANSPORT_ADMIN
  DRIVER
  STUDENT
  PARENT
  STAFF
}

enum VehicleStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
}

enum TripStatus {
  SCHEDULED
  RUNNING
  COMPLETED
  CANCELLED
}

// ----------------------------------------------------------------------------
// MULTI-TENANCY CORE
// ----------------------------------------------------------------------------
model College {
  id        String   @id @default(uuid())
  name      String
  domain    String?  @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users     User[]
  vehicles  Vehicle[]
  routes    Route[]
  trips     Trip[]
}

// ----------------------------------------------------------------------------
// USERS & ROLES
// ----------------------------------------------------------------------------
model User {
  id        String   @id @default(uuid())
  collegeId String?  // Nullable ONLY for SUPER_ADMIN
  email     String   @unique
  password  String
  role      UserRole
  isActive  Boolean  @default(true)
  name      String

  college   College? @relation(fields: [collegeId], references: [id])
  driverProfile DriverProfile?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role])
  @@index([collegeId])
}

model DriverProfile {
  id        String  @id @default(uuid())
  userId    String  @unique
  phone     String?
  licenseNo String?

  user User @relation(fields: [userId], references: [id])
  vehicles VehicleAssignment[]

  createdAt DateTime @default(now())
}

// ----------------------------------------------------------------------------
// ASSETS & ROUTES
// ----------------------------------------------------------------------------
model Vehicle {
  id           String        @id @default(uuid())
  collegeId    String
  registration String        @unique
  type         String
  capacity     Int?
  gpsDeviceId  String?       @unique
  status       VehicleStatus @default(ACTIVE)

  college      College       @relation(fields: [collegeId], references: [id])
  assignments  VehicleAssignment[]
  trips        Trip[]
  locations    LocationHistory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@index([collegeId])
}

model Route {
  id        String  @id @default(uuid())
  collegeId String
  code      String  @unique
  name      String
  city      String
  isActive  Boolean @default(true)

  college   College @relation(fields: [collegeId], references: [id])
  stops     RouteStop[]
  trips     Trip[]
  assignments VehicleAssignment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([collegeId])
  @@index([city])
}

model RouteStop {
  id        String @id @default(uuid())
  routeId   String
  name      String
  latitude  Float
  longitude Float
  sequence  Int

  route Route @relation(fields: [routeId], references: [id])

  @@unique([routeId, sequence])
  @@index([routeId])
}

model VehicleAssignment {
  id        String @id @default(uuid())
  vehicleId String
  driverId  String
  routeId   String

  vehicle Vehicle       @relation(fields: [vehicleId], references: [id])
  driver  DriverProfile @relation(fields: [driverId], references: [id])
  route   Route         @relation(fields: [routeId], references: [id])

  startDate DateTime
  endDate   DateTime?

  @@index([vehicleId])
  @@index([driverId])
  @@index([routeId])
}

// ----------------------------------------------------------------------------
// TRIP EXECUTION
// ----------------------------------------------------------------------------
model Trip {
  id        String     @id @default(uuid())
  collegeId String
  vehicleId String
  routeId   String
  status    TripStatus

  startedAt DateTime?
  endedAt   DateTime?

  college College @relation(fields: [collegeId], references: [id])
  vehicle Vehicle @relation(fields: [vehicleId], references: [id])
  route   Route   @relation(fields: [routeId], references: [id])

  locations LocationHistory[]

  @@index([collegeId])
  @@index([vehicleId])
  @@index([routeId])
}

model LocationHistory {
  id         String   @id @default(uuid())
  vehicleId  String
  tripId     String?
  latitude   Float
  longitude  Float
  speed      Float?
  recordedAt DateTime @default(now())

  vehicle Vehicle @relation(fields: [vehicleId], references: [id])
  trip    Trip?   @relation(fields: [tripId], references: [id])

  @@index([vehicleId, recordedAt])
  @@index([tripId])
}
